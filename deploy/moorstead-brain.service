[Unit]
Description=Moorstead village brain (yorkshire_bot FastAPI)
After=network-online.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=moorstead
WorkingDirectory=/opt/moorstead/yorkshire_bot
EnvironmentFile=/etc/moorstead/brain.env
ExecStart=/opt/moorstead/venv/bin/python -m uvicorn brain.app:app --host 127.0.0.1 --port 8000 --log-level warning
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
